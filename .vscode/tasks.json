{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "prepare build dir",
      "type": "shell",
      "command": "mkdir -p build",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "conan install",
      "type": "shell",
      "command": "conan install .. --build=missing -s compiler.libcxx=libstdc++11",
      "options": {
        "cwd": "${workspaceFolder}/build",
        "env": {}
      },
      "problemMatcher": [],
      "group": "build",
      "dependsOn": "prepare build dir",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "cmake configure",
      "type": "shell",
      "command": "cmake .. -DCMAKE_BUILD_TYPE=Release",
      "options": { "cwd": "${workspaceFolder}/build" },
      "problemMatcher": [],
      "group": "build",
      "dependsOn": "conan install",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "build",
      "type": "shell",
      "command": "cmake --build .",
      "options": { "cwd": "${workspaceFolder}/build" },
      "problemMatcher": ["$gcc", "$msvc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": "cmake configure",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "rebuild (clean + build)",
      "type": "shell",
      "command": "rm -rf * && conan install .. --build=missing && cmake .. -DCMAKE_BUILD_TYPE=Release && cmake --build .",
      "options": { "cwd": "${workspaceFolder}/build" },
      "problemMatcher": ["$gcc", "$msvc"],
      "group": "build",
      "presentation": { "reveal": "always" }
    }
  ]
}
